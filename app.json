{
  "expo": {
    "name": "Basketball Coach AI",
    "slug": "basketball-coach-native",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#120d09"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "hidden": true,
          "style": "dark",
          "enforceContrast": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Basketball Coach AI to use the camera for dribble and shooting analysis.",
          "microphonePermission": "Allow Basketball Coach AI to use the microphone while recording lesson videos."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIStatusBarHidden": true,
        "NSCameraUsageDescription": "Allow Basketball Coach AI to use the camera for dribble and shooting analysis.",
        "NSMicrophoneUsageDescription": "Allow Basketball Coach AI to use the microphone while recording lesson videos."
      }
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#120d09"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
